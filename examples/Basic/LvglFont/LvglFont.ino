#include <M5Unified.h>


extern const uint8_t MontserratBold16[];

extern "C" {
extern const lv_font_t NotoSans_Regular;
};

const lgfx::LVGLfont NotoSans_Regular_Font(&NotoSans_Regular);

void setup(void)
{
    auto cfg = M5.config();
    M5.begin(cfg);

    // lvgl fontbin
    M5.Lcd.loadFont(MontserratBold16);
    M5.Lcd.setCursor(0, 0);
    M5.Lcd.print("ABCDEFGHJKLMNOPQRSTUVWXYZabcdefghjklmnopqrstuvwxyz0123456789");

    // lvgl built-in font
    M5.Lcd.drawString("Hello World!", 0, 120, &fonts::lv_font_montserrat_16);
    // lvgl font with custom font class
    M5.Lcd.drawString("Hello World!", 0, 160, &NotoSans_Regular_Font);
}



void loop(void)
{
  M5.delay(10);
}

// for ESP-IDF compat
#if !defined ( ARDUINO ) && defined ( ESP_PLATFORM )
extern "C" {
  void loopTask(void*)
  {
    setup();
    for (;;) {
      loop();
    }
    vTaskDelete(NULL);
  }

  void app_main()
  {
    xTaskCreatePinnedToCore(loopTask, "loopTask", 8192, NULL, 1, NULL, 1);
  }
}
#endif

